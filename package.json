{
    "name": "redpill-monorepo",
    "version": "1.0.0",
    "private": true,
    "description": "Redpill monorepo — JS and Python SDKs for AI-powered chart generation",
    "workspaces": [
        "packages/js/redpill",
        "packages/js/webapp",
        "packages/python/webapp"
    ],
    "scripts": {
        "build": "npm run build --workspace=packages/js/redpill",
        "test": "npm run test --workspace=packages/js/redpill",
        "lint": "npm run lint --workspace=packages/js/redpill",
        "dev:js": "npm run dev --workspace=packages/js/webapp",
        "dev:python": "npm run dev --workspace=packages/python/webapp",
        "publish:js": "npm run build --workspace=packages/js/redpill && npm publish --workspace=packages/js/redpill --access public",
        "clean": "rimraf packages/js/redpill/dist packages/js/redpill/node_modules"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/your-org/redpill.git"
    },
    "devDependencies": {
        "rimraf": "^5.0.0"
    }
}